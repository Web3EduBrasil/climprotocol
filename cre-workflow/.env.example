# ==========================================================================
# CRE Workflow — Environment Variables
# ==========================================================================
# Copy this file to .env and replace the values.
#
# IMPORTANT: Never commit the .env file to git!
# ==========================================================================

# Private key for chain writes (must be funded on Sepolia with ETH)
# This key is used by the CRE workflow to call SettlementEngine.performUpkeep()
CRE_ETH_PRIVATE_KEY=your_funded_sepolia_private_key_here
