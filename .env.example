# Example environment variables for Clim Protocol

# Network Configuration
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Wallet Configuration
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Chainlink Configuration (you'll get these after creating subscriptions)
FUNCTIONS_SUBSCRIPTION_ID=1
AUTOMATION_UPKEEP_ID=

# Contract Addresses (filled after deployment)
PROTOCOL_ADDRESS=
TOKEN_ADDRESS=
FACTORY_ADDRESS=
POOL_ADDRESS=
SETTLEMENT_ADDRESS=
ORACLE_ADDRESS=

# Frontend Configuration
NEXT_PUBLIC_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
NEXT_PUBLIC_PROTOCOL_ADDRESS=
NEXT_PUBLIC_TOKEN_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_POOL_ADDRESS=
NEXT_PUBLIC_SETTLEMENT_ADDRESS=
NEXT_PUBLIC_ORACLE_ADDRESS=